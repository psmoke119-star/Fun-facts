# Fun-facts
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Random Fun Facts</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
            max-width: 600px;
            width: 100%;
            padding: 50px;
            text-align: center;
        }

        h1 {
            color: #333;
            margin-bottom: 10px;
            font-size: 2.5em;
        }

        .subtitle {
            color: #666;
            margin-bottom: 40px;
            font-size: 1.1em;
        }

        .fact-box {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 30px;
            border-radius: 10px;
            margin: 30px 0;
            min-height: 120px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3em;
            line-height: 1.6;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.2);
            animation: fadeIn 0.5s ease-in;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .button-group {
            display: flex;
            gap: 15px;
            justify-content: center;
            flex-wrap: wrap;
        }

        button {
            background: #667eea;
            color: white;
            border: none;
            padding: 12px 30px;
            font-size: 1em;
            border-radius: 5px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: 600;
        }

        button:hover {
            background: #764ba2;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }

        button:active {
            transform: translateY(0);
        }

        .fact-counter {
            color: #999;
            font-size: 0.9em;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🎉 Fun Facts</h1>
        <p class="subtitle">Click the button below to discover amazing facts!</p>
        
        <div class="fact-box" id="factBox">
            Click "New Fact" to get started!
        </div>

        <div class="button-group">
            <button onclick="getRandomFact()">New Fact</button>
            <button onclick="location.reload()">Reset</button>
        </div>

        <p class="fact-counter">Facts seen: <span id="counter">0</span></p>
    </div>

    <script>
        const facts = [
            "Honey never spoils. Archaeologists have found pots of honey in ancient Egyptian tombs that are over 3,000 years old and still edible!",
            "A group of flamingos is called a 'flamboyance'.",
            "Octopuses have three hearts: two pump blood to the gills, and one pumps it to the rest of the body.",
            "The shortest war in history lasted only 38 to 45 minutes. It was between Britain and Zanzibar in 1896.",
            "Bananas are berries, but strawberries aren't! Botanically speaking, bananas are berries but strawberries are not.",
            "A tarantula can live up to 30 years.",
            "The Great Wall of China is not visible from space without aid.",
            "Cleopatra lived closer to the moon landing than to the building of the Great Pyramid of Giza.",
            "Wombats poop in cubes to prevent it from rolling away.",
            "Dolphins have names for each other that they call out.",
            "A group of crows is called a 'murder'.",
            "Sloths only defecate once a week.",
            "The fingerprints of koalas are so similar to human fingerprints that they've been confused at crime scenes!",
            "Penguins propose to their partners with a pebble.",
            "A day on Venus is longer than its year.",
            "Ants don't have ears. They 'hear' by sensing vibrations through the ground.",
            "Butterflies taste with their feet.",
            "The smell of fresh-cut grass is actually a plant distress signal.",
            "Polar bears have black skin under their white fur.",
            "A crocodile cannot stick its tongue out.",
            "Carrots were originally purple, not orange.",
            "Scotland's national animal is a unicorn.",
            "Cats have a third eyelid called the nictitating membrane.",
            "A group of pandas is called an 'embarrassment'.",
            "The Eiffel Tower can be 15 cm taller during the summer due to thermal expansion."
        ];

        let factsShown = 0;

        function getRandomFact() {
            const randomIndex = Math.floor(Math.random() * facts.length);
            const factBox = document.getElementById('factBox');
            
            factBox.style.animation = 'none';
            setTimeout(() => {
                factBox.textContent = facts[randomIndex];
                factBox.style.animation = 'fadeIn 0.5s ease-in';
            }, 10);

            factsShown++;
            document.getElementById('counter').textContent = factsShown;
        }

        // Load a fact on page load
        window.addEventListener('load', getRandomFact);
    </script>
</body>
</html>
